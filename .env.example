# ─────────────────────────────────────────────────────────────────
# Saral — .env.example
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# All values here are safe defaults / placeholders.
# ─────────────────────────────────────────────────────────────────

# ── IBM watsonx.ai credentials (REQUIRED for AI features) ─────────
# Get your API key from: IBM Cloud → Manage → Access (IAM) → API keys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# Get your Project ID from: watsonx.ai dashboard → project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Cloud region endpoint — change region to match your watsonx.ai project
# Options: au-syd (Sydney) | us-south (Dallas) | eu-de (Frankfurt) | eu-gb (London)
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Foundation model to use (change to swap model, no code changes needed)
# Options: meta-llama/llama-3-3-70b-instruct | ibm/granite-13b-instruct-v2
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── Flask ──────────────────────────────────────────────────────────
# Set to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-long-random-secret-string

# Set to false in production
FLASK_DEBUG=true

# ── File upload ────────────────────────────────────────────────────
# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=25

# ── Rate limiting (IBM Lite plan optimisation) ─────────────────────
# Limits are per-IP. Tune these to stay within your IBM quota.
# IBM Lite plan recommended: 5/minute, 50/day for development
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_DAY=50
